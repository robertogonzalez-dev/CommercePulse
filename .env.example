# CommercePulse — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Warehouse ─────────────────────────────────────────────────────────────────
# Override the default DuckDB path (default: data/warehouse/commercepulse.duckdb)
# CP_DB_PATH=data/warehouse/commercepulse.duckdb

# ── API ───────────────────────────────────────────────────────────────────────
# CP_API_HOST=0.0.0.0
# CP_API_PORT=8000
# CP_DEBUG=false
# CP_CORS_ORIGINS=["http://localhost:8501","http://localhost:3000"]

# ── Streamlit App ─────────────────────────────────────────────────────────────
# CP_API_BASE_URL=http://localhost:8000
# CP_CACHE_TTL_SECONDS=300

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

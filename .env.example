# CommercePulse — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── Warehouse ─────────────────────────────────────────────────
COMMERCEPULSE_DB_PATH=data/warehouse/commercepulse.duckdb

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs

# ── API ───────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=true
